<odoo>
    <record id="view_chatbot_form" model="ir.ui.view">
        <field name="name">chatbot.message.form</field>
        <field name="model">chatbot.message</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="user_message"/>
                        <field name="bot_response" readonly="1"/>
                    </group>
                    <footer>
                        <button name="send_to_api"
                                type="object"
                                string="Enviar"
                                class="btn-primary"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_chatbot" model="ir.actions.act_window">
        <field name="name">Chatbot</field>
        <field name="res_model">chatbot.message</field>
        <field name="view_mode">form,tree</field>
    </record>

    <menuitem id="menu_chatbot_root" name="Chatbot"/>
    <menuitem id="menu_chatbot"
              name="Conversaciones"
              parent="menu_chatbot_root"
              action="action_chatbot"/>
</odoo>