<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Inyectamos el widget flotante en TODAS las páginas del sitio,
        heredando del layout base de website. El template se activa
        automáticamente cuando este módulo está instalado.
    -->
    <template id="chat_widget_inject"
              name="Chat UMayor Widget"
              inherit_id="website.layout"
              priority="50">
        <xpath expr="//footer" position="after">
            <t t-call="chat_umayor_ui.chat_widget_template"/>
        </xpath>
    </template>

    <!--
        Template del widget flotante. Es solo MARKUP. Toda la lógica
        está en el JS (ver static/src/js/chat_widget.js).
    -->
    <template id="chat_widget_template" name="Chat UMayor - Widget">
        <div id="cu_chat_widget" class="cu-widget" aria-live="polite">
            <!-- Burbuja flotante (cerrada por defecto) -->
            <button type="button"
                    id="cu_chat_toggle"
                    class="cu-widget__toggle"
                    aria-label="Abrir chat con asistente"
                    title="Habla con nuestro asistente">
                <svg class="cu-widget__toggle-icon cu-widget__toggle-icon--open"
                     viewBox="0 0 24 24" width="28" height="28" aria-hidden="true">
                    <path d="M4 4h16a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H8l-4 4V6a2 2 0 0 1 2-2z"
                          fill="currentColor"/>
                </svg>
                <svg class="cu-widget__toggle-icon cu-widget__toggle-icon--close"
                     viewBox="0 0 24 24" width="22" height="22" aria-hidden="true">
                    <path d="M6 6l12 12M18 6L6 18" stroke="currentColor"
                          stroke-width="2.5" stroke-linecap="round" fill="none"/>
                </svg>
            </button>

            <!-- Panel del chat -->
            <section class="cu-widget__panel" role="dialog"
                     aria-labelledby="cu_chat_title" aria-hidden="true">
                <header class="cu-widget__header">
                    <div class="cu-widget__brand">
                        <span class="cu-widget__brand-dot" aria-hidden="true"/>
                        <div>
                            <h2 id="cu_chat_title" class="cu-widget__title">Asistente UMayor</h2>
                            <p class="cu-widget__subtitle">En línea</p>
                        </div>
                    </div>
                    <button type="button" class="cu-widget__minimize"
                            id="cu_chat_minimize" aria-label="Minimizar">
                        <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
                            <path d="M5 13h14" stroke="currentColor"
                                  stroke-width="2.5" stroke-linecap="round"/>
                        </svg>
                    </button>
                </header>

                <div class="cu-widget__messages" id="cu_chat_messages" role="log">
                    <!-- Los mensajes se insertan dinámicamente desde el JS -->
                </div>

                <div class="cu-widget__suggestions" id="cu_chat_suggestions">
                    <!-- Chips de productos sugeridos, se llenan desde JS -->
                </div>

                <form class="cu-widget__form" id="cu_chat_form" autocomplete="off">
                    <input type="text"
                           id="cu_chat_input"
                           class="cu-widget__input"
                           placeholder="Escribe tu consulta..."
                           aria-label="Mensaje"
                           maxlength="500"
                           required="required"/>
                    <button type="submit" class="cu-widget__send" aria-label="Enviar">
                        <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
                            <path d="M3 12l18-9-7 18-3-8-8-1z" fill="currentColor"/>
                        </svg>
                    </button>
                </form>

                <footer class="cu-widget__footer">
                    <span>Banco UMayor · Powered by Odoo</span>
                </footer>
            </section>
        </div>
    </template>

    <!--
        Página dedicada /chat - usa el mismo widget pero abierto a pantalla
        completa. Útil cuando el cliente quiere conversar sin distracciones.
    -->
    <template id="chat_page_template" name="Chat UMayor - Página dedicada">
        <t t-call="website.layout">
            <div id="wrap" class="cu-page">
                <div class="container py-5">
                    <div class="cu-page__hero text-center mb-4">
                        <h1 class="cu-page__title">¿En qué te podemos ayudar?</h1>
                        <p class="cu-page__lead">
                            Conversa con nuestro asistente y descubre el producto financiero
                            ideal para ti. Disponible 24/7.
                        </p>
                    </div>
                    <div class="cu-page__chatframe">
                        <p class="text-muted text-center">
                            El widget de chat aparece en la esquina inferior derecha.
                            Haz clic en él para comenzar.
                        </p>
                    </div>
                </div>
            </div>
        </t>
    </template>

</odoo>
