<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_chat_message_list" model="ir.ui.view">
        <field name="name">chat.umayor.message.list</field>
        <field name="model">chat.umayor.message</field>
        <field name="arch" type="xml">
            <list string="Mensajes">
                <field name="create_date"/>
                <field name="session_id"/>
                <field name="role" widget="badge"/>
                <field name="content"/>
                <field name="response_time_ms" string="ms"/>
            </list>
        </field>
    </record>

    <record id="action_chat_message" model="ir.actions.act_window">
        <field name="name">Mensajes</field>
        <field name="res_model">chat.umayor.message</field>
        <field name="view_mode">list</field>
    </record>

</odoo>
