<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Vista lista de sesiones -->
    <record id="view_chat_session_list" model="ir.ui.view">
        <field name="name">chat.umayor.session.list</field>
        <field name="model">chat.umayor.session</field>
        <field name="arch" type="xml">
            <list string="Sesiones de Chat" decoration-success="state=='completed'" decoration-warning="state=='awaiting_otp' or state=='awaiting_signature'" decoration-muted="state=='abandoned'">
                <field name="create_date" string="Inicio"/>
                <field name="visitor_name"/>
                <field name="visitor_email"/>
                <field name="product_id"/>
                <field name="message_count"/>
                <field name="response_avg_ms" widget="integer" string="Tiempo medio (ms)"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <!-- Vista formulario -->
    <record id="view_chat_session_form" model="ir.ui.view">
        <field name="name">chat.umayor.session.form</field>
        <field name="model">chat.umayor.session</field>
        <field name="arch" type="xml">
            <form string="Sesión de Chat">
                <header>
                    <button name="action_mark_completed" type="object" string="Marcar como completada" class="btn-primary" invisible="state == 'completed'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,active,awaiting_otp,awaiting_signature,completed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="token"/>
                        <h1><field name="token" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="visitor_name"/>
                            <field name="visitor_email"/>
                            <field name="visitor_phone"/>
                            <field name="partner_id"/>
                        </group>
                        <group>
                            <field name="product_id"/>
                            <field name="sign_request_ref"/>
                            <field name="message_count"/>
                            <field name="response_avg_ms" widget="integer"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Mensajes">
                            <field name="message_ids">
                                <list>
                                    <field name="create_date" string="Hora"/>
                                    <field name="role" widget="badge"/>
                                    <field name="content"/>
                                    <field name="response_time_ms" string="ms"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Vista búsqueda -->
    <record id="view_chat_session_search" model="ir.ui.view">
        <field name="name">chat.umayor.session.search</field>
        <field name="model">chat.umayor.session</field>
        <field name="arch" type="xml">
            <search>
                <field name="visitor_name"/>
                <field name="visitor_email"/>
                <field name="token"/>
                <filter string="Activas" name="filter_active" domain="[('state','=','active')]"/>
                <filter string="Esperando firma" name="filter_sign" domain="[('state','=','awaiting_signature')]"/>
                <filter string="Completadas" name="filter_done" domain="[('state','=','completed')]"/>
                <group expand="0" string="Agrupar por">
                    <filter string="Estado" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Producto" name="group_product" context="{'group_by': 'product_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Acción -->
    <record id="action_chat_session" model="ir.actions.act_window">
        <field name="name">Sesiones de Chat</field>
        <field name="res_model">chat.umayor.session</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_chat_session_search"/>
    </record>

</odoo>