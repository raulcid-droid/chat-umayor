<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Productos financieros de muestra para la demo -->
        <record id="product_credito_consumo" model="chat.umayor.product">
            <field name="name">Crédito de Consumo</field>
            <field name="code">CRED_CONSUMO</field>
            <field name="sequence">10</field>
            <field name="short_description">Crédito flexible para tus proyectos</field>
            <field name="description">Crédito en cuotas desde 6 hasta 48 meses, con tasa preferencial para clientes nuevos.</field>
            <field name="interest_rate">1.45</field>
            <field name="min_amount">1000000</field>
            <field name="max_amount">30000000</field>
        </record>

        <record id="product_tarjeta_gold" model="chat.umayor.product">
            <field name="name">Tarjeta de Crédito Gold</field>
            <field name="code">TC_GOLD</field>
            <field name="sequence">20</field>
            <field name="short_description">Beneficios premium y cashback</field>
            <field name="description">Tarjeta Gold con cashback del 2% en supermercados y seguro de viajes incluido.</field>
            <field name="interest_rate">2.85</field>
            <field name="min_amount">500000</field>
            <field name="max_amount">8000000</field>
        </record>

        <record id="product_cuenta_ahorro" model="chat.umayor.product">
            <field name="name">Cuenta de Ahorro Plus</field>
            <field name="code">AHORRO_PLUS</field>
            <field name="sequence">30</field>
            <field name="short_description">Ahorra y obtén intereses competitivos</field>
            <field name="description">Cuenta de ahorro con interés mensual capitalizable, sin costo de mantención.</field>
            <field name="interest_rate">0.45</field>
            <field name="min_amount">0</field>
            <field name="max_amount">0</field>
        </record>

    </data>
</odoo>
